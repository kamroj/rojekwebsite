---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHeaderSsg from '../../components/_astro/ssg/PageHeaderSsg.astro';
import containerStyles from '../../components/ui/MaxWidthContainer.module.css';
---

<SiteLayout
  lang="en"
  title="Cookies Policy – ROJEK"
  description="Cookies Policy of ROJEK"
>
  <PageHeaderSsg
    imageSrc="/images/policy/policy-top.webp"
    title="Cookies Policy"
    height={500}
  />

  <main class="legal-page">
    <div class={containerStyles.root} data-max-width-container="true">
      <article class="legal-content">
      <p><strong>Effective date: 18.02.2026</strong></p>

      <h2>1. What are cookies?</h2>
      <p>Cookies are small text files stored on the user’s device while using a website.</p>

      <h2>2. Types of cookies used</h2>
      <h3>A. Essential cookies</h3>
      <p>They ensure proper website operation and security.</p>

      <h3>B. Analytical cookies (Google Analytics)</h3>
      <p>They allow us to analyze website traffic and user behavior.</p>
      <p>They are activated only after consent is given.</p>

      <h2>3. Cookie management</h2>
      <p>During the first visit, the user can:</p>
      <ul>
        <li>accept all cookies,</li>
        <li>reject analytical cookies,</li>
        <li>customize settings.</li>
      </ul>
      <p>Settings can be changed at any time through browser configuration.</p>

      <h2>4. Data transferred to Google</h2>
      <p>In connection with the use of Google Analytics and reCAPTCHA, data may be transferred to Google LLC.</p>
      <p>Details:</p>
      <p><a href="https://policies.google.com/privacy">https://policies.google.com/privacy</a></p>
      <p><a href="https://policies.google.com/technologies/cookies">https://policies.google.com/technologies/cookies</a></p>
      </article>
    </div>
  </main>

  <style>
    .legal-page {
      padding: var(--space-lg) 0 var(--space-xl);
      background: var(--color-background);
    }

    .legal-content {
      max-width: none;
      width: 100%;
      font-family: var(--font-main);
      color: var(--color-text-dark);
    }

    .legal-content h2,
    .legal-content h3 {
      font-family: var(--font-heading);
      color: var(--color-bottle-green);
      font-weight: 500;
      line-height: 1.3;
      margin: 2rem 0 0.8rem;
    }

    .legal-content h2 { font-size: clamp(1.9rem, 2.2vw, 2.4rem); }
    .legal-content h3 { font-size: clamp(1.7rem, 2vw, 2rem); margin-top: 1.6rem; }
    .legal-content p, .legal-content li { font-size: 1.6rem; line-height: 1.4; color: #1f2937; }
    .legal-content p { margin: 0 0 1rem; }
    .legal-content ul { margin: 0 0 1rem; padding-left: 2rem; display: grid; gap: 0.35rem; }
    .legal-content a { color: var(--color-primary); text-decoration: underline; text-underline-offset: 2px; word-break: break-word; }
  </style>
</SiteLayout>
